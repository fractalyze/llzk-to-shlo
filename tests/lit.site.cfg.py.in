import os
import lit.llvm

# Find the runfiles directory
runfiles_dir = os.environ.get("RUNFILES_DIR")
if not runfiles_dir:
    # Fallback for direct execution
    runfiles_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))

workspace_name = "llzk_to_shlo"
config.llvm_tools_dir = os.path.join(runfiles_dir, workspace_name, "@LLVM_TOOLS_DIR@")
config.llzk_to_shlo_tools_dir = os.path.join(runfiles_dir, workspace_name, "@LLZK_TO_SHLO_TOOLS_DIR@")
config.test_source_root = os.path.join(runfiles_dir, workspace_name, "tests")

lit.llvm.initialize(lit_config, config)

# Let the main config do the real work.
lit_config.load_config(
    config, os.path.join(runfiles_dir, workspace_name, "tests", "lit.cfg.py"))
