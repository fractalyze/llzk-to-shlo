# NOTE: Currently, building with Bzlmod causes a python_repository attribute error
# (e.g., missing python_version_kind).
common --noenable_bzlmod

# Build with C++17
build --cxxopt=-std=c++17
build --host_cxxopt=-std=c++17

# Default to optimized builds
build -c opt

# Debug configuration
build:debug -c dbg
build:debug --copt=-g
build:debug --strip=never

# ASAN configuration
build:asan --config=debug
build:asan --copt=-fsanitize=address
build:asan --copt=-fno-omit-frame-pointer
build:asan --linkopt=-fsanitize=address

# MSAN configuration
build:msan --config=debug
build:msan --copt=-fsanitize=memory
build:msan --copt=-fno-omit-frame-pointer
build:msan --linkopt=-fsanitize=memory

# TSAN configuration
build:tsan --config=debug
build:tsan --copt=-fsanitize=thread
build:tsan --linkopt=-fsanitize=thread
